---
import ProjectCard from '../../components/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Nemotron-3 Reasoning Challenge',
    description:
      'LoRA fine-tuning harness for a 30B reasoning model with distributed training across dual RTX PRO 6000s + DGX Spark, programmatic synthetic puzzle generation, and an automated eval pipeline. Kaggle competition, $25K+ prize pool.',
    year: '2026, ongoing',
  },
  {
    title: 'ARC Prize 2026 — ARC-AGI-3',
    description:
      'Building agents that adapt to novel, human-solvable tasks never seen during training. Hidden interactive environments, multi-step reasoning, and no memorization shortcuts. $850K prize pool. Kaggle competition, November 2026 deadline.',
    year: '2026, ongoing',
    href: 'https://kaggle.com/competitions/arc-prize-2026-arc-agi-3',
  },
  {
    title: 'ml-eval-harness',
    description:
      'Lightweight evaluation framework for comparing local LLMs via Ollama. Multi-metric scoring (exact match, token F1, LLM-as-judge), latency analysis, and an interactive ECharts dashboard with heatmaps and per-item drill-down.',
    year: '2026',
    href: 'https://github.com/rama-kata/ml-eval-harness',
  },
];
---

<BaseLayout title="Projects" description="Projects by Riiny Giir.">
  <section class="mx-auto max-w-4xl py-24 text-center sm:py-32" aria-labelledby="projects-title">
    <h1 id="projects-title" class="text-6xl font-semibold leading-[0.95] tracking-tight sm:text-7xl">
      I like to build
      <span class="font-display block italic text-[0.92em] text-[var(--color-muted-foreground)] dark:text-[var(--color-muted-foreground-on-dark)]">
        reasoning systems from scratch
      </span>
    </h1>
    <p class="mx-auto mt-8 max-w-2xl text-base leading-relaxed text-[var(--color-muted-foreground)] dark:text-[var(--color-muted-foreground-on-dark)]">
      Applied ML, distributed training, and product systems work.
    </p>
  </section>

  <section class="pb-24" aria-labelledby="project-list-title">
    <div class="mb-8 flex items-center justify-between">
      <h2 id="project-list-title" class="font-display text-3xl italic">Projects</h2>
      <a class="text-sm text-[var(--color-muted-foreground)] dark:text-[var(--color-muted-foreground-on-dark)]" href="/contact">Get in touch</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>
</BaseLayout>
